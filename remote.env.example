# ==============================================================
# Remote Server Configuration
# Copy this to remote.env and fill in your values
# ==============================================================

# SSH connection details
REMOTE_USER=your-username
REMOTE_HOST=your-server-ip-or-hostname

# Ports (change if they conflict)
REMOTE_PORT=8000
LOCAL_PORT=8000
FRONTEND_PORT=5173

# ---- On the remote server ----
# Where models and datasets are stored
# VGUARD_DATA_DIR=/data/models

# Force mock mode (true/false/auto)
# auto = use mock if no GPU detected
# VGUARD_MOCK_MODE=auto

# Extra CORS origin (if accessing frontend from a different host)
# VGUARD_CORS_ORIGIN=http://your-public-ip:5173
